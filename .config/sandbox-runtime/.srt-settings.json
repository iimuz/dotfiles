{
  "network": {
    "allowedDomains": [
      "github.com",
      "*.github.com",
      "githubusercontent.com",
      "*.githubusercontent.com",
      "npmjs.com",
      "*.npmjs.com",
      "openai.com",
      "*.openai.com",
      "anthropic.com",
      "*.anthropic.com",
      "opencode.ai",
      "*.opencode.ai",
      "*.jina.ai"
    ],
    "deniedDomains": [],
    "allowUnixSockets": ["/var/run/docker.sock"],
    "allowAllUnixSockets": true,
    "allowLocalBinding": false
  },
  "filesystem": {
    "denyRead": ["~/.ssh"],
    "allowRead": ["/tmp/"],
    "allowWrite": [
      ".",
      "/tmp/",
      "~/.cache/",
      "~/.claude/context-mode/",
      "~/.local/state/mise/trusted-configs/",
      "~/.safe-chain/certs/ca-key.pem"
    ],
    "denyWrite": []
  },
  "ignoreViolations": {
    "*": ["/usr/bin", "/System"],
    "git push": ["/usr/bin/nc"],
    "npm": ["/private/tmp"]
  },
  "enableWeakerNestedSandbox": false,
  "enableWeakerNetworkIsolation": false
}
