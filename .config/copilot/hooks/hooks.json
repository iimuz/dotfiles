{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/session-start-cleanup.sh",
        "timeoutSec": 5
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "command": "rtk hook copilot",
        "cwd": ".",
        "timeout": 5
      },
      {
        "type": "command",
        "bash": "python3 $HOME/.copilot/hooks/pre-tool-use-permission.py",
        "timeoutSec": 5
      }
    ]
  }
}
