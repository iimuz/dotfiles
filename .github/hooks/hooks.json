{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "command -v bd > /dev/null 2>&1 && bd prime || true",
        "powershell": "if (Get-Command bd -ErrorAction SilentlyContinue) { bd prime }",
        "cwd": ".",
        "timeoutSec": 3
      }
    ],
    "sessionEnd": [],
    "userPromptSubmitted": [],
    "preToolUse": [],
    "postToolUse": [],
    "agentStop": [
      {
        "type": "command",
        "bash": "mise run format",
        "powershell": "mise run format",
        "cwd": ".",
        "timeoutSec": 30
      }
    ],
    "subagentStop": [],
    "errorOccurred": []
  }
}
